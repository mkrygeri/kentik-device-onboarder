KENTIK_API_EMAIL=example@example.com
KENTIK_API_TOKEN=0000000aaaaaaabbbbbbbcccc
KENTIK_ONBOARDER_FLOWPAK_ID=12345
KENTIK_ONBOARDER_HEALTHCHECK_ADDRESS=127.0.0.1:9996
KENTIK_ONBOARDER_POLL_INTERVAL=5m
KENTIK_ONBOARDER_HEALTHCHECK_TIMEOUT=5s
KENTIK_ONBOARDER_API_ROOT=https://grpc.api.kentik.com
KENTIK_ONBOARDER_REQUEST_TIMEOUT=15s
KENTIK_ONBOARDER_BATCH_SIZE=100
KENTIK_ONBOARDER_SUCCESS_COOLDOWN=24h
KENTIK_ONBOARDER_BACKOFF_BASE=5m
KENTIK_ONBOARDER_BACKOFF_MAX=2h
KENTIK_ONBOARDER_GLOBAL_BACKOFF_BASE=1m
KENTIK_ONBOARDER_GLOBAL_BACKOFF_MAX=30m
KENTIK_ONBOARDER_API_RATE_PER_MINUTE=12
KENTIK_ONBOARDER_API_RATE_BURST=2
KENTIK_ONBOARDER_STATE_FILE=/var/lib/kentik-device-onboarder/state.json
KENTIK_ONBOARDER_LOG_LEVEL=INFO
KENTIK_ONBOARDER_DNS_TIMEOUT=2s
KENTIK_ONBOARDER_DNS_CACHE_TTL=1h
KENTIK_ONBOARDER_DNS_NEGATIVE_CACHE_TTL=5m
# Explicit DNS resolver for reverse lookups. Set this when the system
# resolver does not know how to resolve PTR records for your private IPs.
#   - Empty: use the system resolver.
#   - 'auto' (default): probe for cloud metadata servers at startup and pick
#     169.254.169.254 (GCE), 168.63.129.16 (Azure), or 169.254.169.253 (AWS).
#     Falls back to the system resolver on non-cloud hosts.
#   - An IP[:port], e.g. 169.254.169.254 or 8.8.8.8:53, to force a server.
KENTIK_ONBOARDER_DNS_SERVER=auto

# Outbound HTTP proxy. The onboarder uses Python's standard library, which
# honours the well-known HTTPS_PROXY / HTTP_PROXY / NO_PROXY environment
# variables (the lower-case forms also work). Set them here when the host
# requires a proxy to reach grpc.api.kentik.com. Cloud metadata probes
# (169.254.169.254, 168.63.129.16) always bypass the proxy regardless of
# NO_PROXY, so DNS auto-detect keeps working behind a proxy.
#
# Example:
#   HTTPS_PROXY=http://proxy.corp.example:3128
#   HTTP_PROXY=http://proxy.corp.example:3128
#   NO_PROXY=localhost,127.0.0.1,169.254.169.254,168.63.129.16
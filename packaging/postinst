#!/usr/bin/env bash
# Post-installation script for kentik-device-onboarder.
# Compatible with both DEB (argument: "configure") and RPM (argument: "1" install / "2" upgrade).

set -e

SERVICE_USER=kentik-onboarder
SERVICE_GROUP=kentik-onboarder
INSTALL_DIR=/opt/kentik-device-onboarder
CONFIG_DIR=/etc/kentik-device-onboarder
STATE_DIR=/var/lib/kentik-device-onboarder
SERVICE_NAME=kentik-device-onboarder.service

_configure() {
    if ! getent group "$SERVICE_GROUP" >/dev/null 2>&1; then
        groupadd --system "$SERVICE_GROUP"
    fi

    if ! id -u "$SERVICE_USER" >/dev/null 2>&1; then
        useradd \
            --system \
            --gid "$SERVICE_GROUP" \
            --home-dir "$INSTALL_DIR" \
            --no-create-home \
            --shell /usr/sbin/nologin \
            "$SERVICE_USER"
    fi

    install -d -m 0750 -o "$SERVICE_USER" -g "$SERVICE_GROUP" "$STATE_DIR"

    chown root:"$SERVICE_GROUP" "$CONFIG_DIR"
    chmod 0750 "$CONFIG_DIR"

    if [ ! -f "$CONFIG_DIR/onboarder.env" ]; then
        install -m 0640 -o "$SERVICE_USER" -g "$SERVICE_GROUP" \
            "$CONFIG_DIR/onboarder.env.example" \
            "$CONFIG_DIR/onboarder.env"
        echo "Created initial configuration file: $CONFIG_DIR/onboarder.env"
        echo "Edit this file and add your Kentik credentials before starting the service."
    fi

    chown root:"$SERVICE_GROUP" "$INSTALL_DIR"
    chown "$SERVICE_USER":"$SERVICE_GROUP" "$INSTALL_DIR/kentik_device_onboarder.py"

    if command -v systemctl >/dev/null 2>&1; then
        systemctl daemon-reload
        systemctl enable "$SERVICE_NAME"
        echo "Service enabled. Start with: systemctl start $SERVICE_NAME"
    fi
}

# DEB passes "configure"; RPM passes "1" (install) or "2" (upgrade).
case "${1:-}" in
    configure|1|2)
        _configure
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
    *)
        # Unknown argument — still run configuration so bare invocation works.
        _configure
        ;;
esac

exit 0
